# Supabase project URL — found in Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Public anon key (safe to expose to the browser, protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER-SIDE ONLY. Never expose to the browser.
# Used by admin API routes to bypass RLS for trusted operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
